# .env.example — copy to .env and fill in values
# Never commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────

# Base URL of your self-hosted Coolify instance. No trailing slash.
# NEVER set this to https://app.coolify.io.
COOLIFY_BASE_URL=https://coolify.example.com

# Coolify API token. Format: <id>|<secret>
# Generate in Coolify → Settings → API Tokens.
COOLIFY_TOKEN=1|your_token_secret_here

# ── SSH / Host-Ops (required when using --enable-host-ops) ───────────────────

# Hostname or IP address of the Coolify host.
COOLIFY_SSH_HOST=your.coolify.host.ip

# SSH login user. Typically root for self-hosted Coolify.
COOLIFY_SSH_USER=root

# SSH port (default: 22).
COOLIFY_SSH_PORT=22

# Absolute path to the SSH private key.
COOLIFY_SSH_KEY_PATH=/root/.ssh/id_rsa

# ── Optional ──────────────────────────────────────────────────────────────────

# Coolify version string for drift detection warnings (e.g. 4.0.0-beta.470).
# COOLIFY_PINNED_VERSION=4.0.0-beta.470
